# Keystore-based authentication (recommended)
# Run `node sdk/keygen.mjs` once to generate keystore.json from your private key.
# Then set these two vars — never put your raw private key here.
KEYSTORE_PATH=/path/to/keystore.json
KEYSTORE_PASSWORD=your_keystore_password_here

# Legacy fallback (not recommended — use keystore instead)
# PRIVATE_KEY=0x_your_ethereum_private_key_here

# API Keys
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
ETHERSCAN_API_KEY=your_etherscan_key_here

# Server
EXTERNAL_IP=your_server_public_ip
