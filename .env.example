# ── Secrets (choose one path) ─────────────────────────────────────────────────

# Recommended: age-encrypted secrets file
# One-time setup on the host:
#   age-keygen -o /secure/age-identity.key && chmod 600 /secure/age-identity.key
#   echo '{"KEYSTORE_PASSWORD":"strong-password"}' | \
#     age -r $(age-keygen -y /secure/age-identity.key) > /secure/worker.secrets.age
#   chmod 600 /secure/worker.secrets.age
SECRETS_PATH=/secure/worker.secrets.age
AGE_IDENTITY_PATH=/secure/age-identity.key

# Keystore file — generated once by sdk/keygen.mjs, store outside repo
KEYSTORE_PATH=/secure/worker.keystore.json

# Legacy: plain-text password — accepted with a deprecation warning, remove after migration
# KEYSTORE_PASSWORD=your_keystore_password_here

# ── API Keys ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your_deepseek_key_here
ETHERSCAN_API_KEY=your_etherscan_key_here

# ── Network ───────────────────────────────────────────────────────────────────
EXTERNAL_IP=your_server_public_ip
REGISTRY_URL=http://localhost:3000
