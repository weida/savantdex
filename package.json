{
  "name": "@wei612/savantdex",
  "version": "0.8.0",
  "type": "module",
  "description": "Agent marketplace SDK — relay-first transport, wallet-verifiable identity, pay-per-task off-chain ledger, optional Streamr P2P",
  "main": "sdk/index.mjs",
  "exports": {
    ".": "./sdk/index.mjs",
    "./gateway": "./sdk/gateway-requester.mjs",
    "./relay": "./sdk/relay-agent.mjs",
    "./mcp": "./sdk/mcp-server.mjs",
    "./canonical": "./sdk/canonical.mjs",
    "./attestation": "./sdk/attestation.mjs"
  },
  "bin": {
    "savantdex-mcp":            "./sdk/mcp-server.mjs",
    "savantdex-verify-receipt": "./scripts/verify-receipt.mjs",
    "savantdex-verify-export":  "./scripts/verify-export.mjs"
  },
  "keywords": [
    "ai-agent",
    "agent-marketplace",
    "agent-sdk",
    "relay",
    "wallet-auth",
    "eip-191",
    "mcp",
    "web3",
    "sdk"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/weida/savantdex",
  "repository": {
    "type": "git",
    "url": "https://github.com/weida/savantdex.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ethers": "^6.0.0",
    "ws": "^8.20.0",
    "zod": "^3.0.0"
  },
  "peerDependencies": {
    "@streamr/sdk": ">=100.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "sdk/*.mjs",
    "!sdk/*.test.mjs",
    "scripts/verify-receipt.mjs",
    "scripts/verify-export.mjs",
    "README.md"
  ]
}
